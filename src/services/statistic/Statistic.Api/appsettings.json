{
  "AllowedHosts": "*",
  "App": {
    "Name": "Statistic Service",
    "Description": "Open API Documentation of Statistic Service API.",
    "Versions": [ 1 ]
  },
  "SerilogOptions": {
    "WriteToFile": true,
    "StructuredConsoleLogging": false,
    "EnableEnrichers": true,
    "MinimumLogLevel": "Debug"
  },
  "HealthOptions": {
    "Postgres": false,
    "Redis": false,
    "RabbitMq": false,
    "OpenIdConnectServer": true,
    "ApplicationStatus": true
  },
  "Keycloak": {
    "realm": "Teck-Cloud",
    "auth-server-url": "https://auth.tecklab.dk/",
    "ssl-required": "external",
    "resource": "teck-statistic",
    "verify-token-audience": true,
    "credentials": {
      "secret": "__change_me__"
    },
    "use-resource-role-mappings": true,
    "confidential-port": 0
  },
  "ConnectionStrings": {
    "rabbitmq": "rabbitmq://guest:guest@localhost:5672/"
  }
}
