{
  "AllowedHosts": "*",
  "App": {
    "Name": "Image Generator Service",
    "Description": "Open API Documentation of Image Generator Service API.",
    "Versions": [ 1 ]
  },
  "SerilogOptions": {
    "WriteToFile": true,
    "StructuredConsoleLogging": false,
    "EnableEnrichers": true,
    "MinimumLogLevel": "Debug"
  },
  "ImageStorage": {
    "Provider": "local"
  },
  "ConnectionStrings": {
    "rabbitmq": "rabbitmq://guest:guest@localhost:5672/"
  }
}
