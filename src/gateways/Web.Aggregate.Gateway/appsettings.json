{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "verify-token-audience": true
  },
      "AppOptions": {
        "Name": "Aggregate.Gateway"
    },
    "SerilogOptions": {
        "WriteToFile": false,
        "StructuredConsoleLogging": false,
        "EnableEnrichers": true
    },
    "HealthOptions": {
        "Postgres": false,
        "Redis": false,
        "RabbitMq": false,
        "OpenIdConnectServer": true,
        "ApplicationStatus": true
    }
}
