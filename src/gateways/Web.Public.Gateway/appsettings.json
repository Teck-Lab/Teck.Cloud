                                "PrefixPath": "/device",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "location": {
                "Destinations": {
                    "Default": {
                        "Address": "http://location-api",
                        "AccessTokenClientName": "teck-location",
                        "Swaggers": [
                            {
                                "PrefixPath": "/location",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "order": {
                "Destinations": {
                    "Default": {
                        "Address": "http://order-api",
                        "AccessTokenClientName": "teck-order",
                        "Swaggers": [
                            {
                                "PrefixPath": "/order",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "product": {
                "Destinations": {
                    "Default": {
                        "Address": "http://product-api",
                        "AccessTokenClientName": "teck-product",
                        "Swaggers": [
                            {
                                "PrefixPath": "/product",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "statistic": {
                "Destinations": {
                    "Default": {
                        "Address": "http://statistic-api",
                        "AccessTokenClientName": "teck-statistic"
                    }
                }
            },
            "imagegenerator": {
                "Destinations": {
                    "Default": {
                        "Address": "http://image-generator",
                        "AccessTokenClientName": "teck-image-generator"
                    }
                }
            },
            "billing": {
                "Destinations": {
                    "Default": {
                        "Address": "http://billing-api",
                        "AccessTokenClientName": "teck-billing",
                        "Swaggers": [
                            {
                                "PrefixPath": "/billing",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            }
        }
    },
    "AllowedHosts": "*"
}
