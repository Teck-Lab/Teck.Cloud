{
    "AppOptions": {
        "Name": "Gateway"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "SerilogOptions": {
        "WriteToFile": false,
        "StructuredConsoleLogging": false,
        "EnableEnrichers": true
    },
    "HealthOptions": {
        "Postgres": false,
        "Redis": false,
        "RabbitMq": false,
        "OpenIdConnectServer": true,
        "ApplicationStatus": true
    },
    "SwaggerOptions": {
        "Title": "Gateway Service",
        "Description": "Open API Documentation of Gateway Service"
    },
    "Keycloak": {
        "verify-token-audience": true
    },
    "MultiTenancy": {
        "TenantIdHeaderName": "X-TenantId",
        "OrganizationClaimName": "organization",
        "TenantIdClaimName": "tenant_id"
    },
    "Services": {
        "CatalogApi": {
            "Url": "http://catalog-api"
        },
        "CustomerApi": {
            "Url": "http://customer-api"
        },
        "BasketApi": {
            "Url": "http://basket-api"
        },
        "DeviceApi": {
            "Url": "http://device-api"
        },
        "LocationApi": {
            "Url": "http://location-api"
        },
        "OrderApi": {
            "Url": "http://order-api"
        },
        "ProductApi": {
            "Url": "http://product-api"
        },
        "StatisticApi": {
            "Url": "http://statistic-api"
        },
        "ImageGeneratorApi": {
            "Url": "http://image-generator"
        },
        "BillingApi": {
            "Url": "http://billing-api"
        }
    },
    "ReverseProxy": {
        "Routes": {
            "catalog-openapi-v1-public": {
                "ClusterId": "catalog",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/catalog/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "catalog-openapi-v3-public": {
                "ClusterId": "catalog",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/catalog/openapi/v3-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v3-public/openapi.json"
                    }
                ]
            },
            "customer-openapi-v1-public": {
                "ClusterId": "customer",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/customer/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "catalog": {
                "ClusterId": "catalog",
                "Match": {
                    "Path": "/catalog/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/catalog/{**catch-all}"
                    }
                ]
            },
            "customer": {
                "ClusterId": "customer",
                "Match": {
                    "Path": "/customer/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/customer/{**catch-all}"
                    }
                ]
            },
            "basket-openapi-v1-public": {
                "ClusterId": "basket",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/basket/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "basket": {
                "ClusterId": "basket",
                "Match": {
                    "Path": "/basket/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/basket/{**catch-all}"
                    }
                ]
            },
            "device-openapi-v1-public": {
                "ClusterId": "device",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/device/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "device": {
                "ClusterId": "device",
                "Match": {
                    "Path": "/device/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/device/{**catch-all}"
                    }
                ]
            },
            "location-openapi-v1-public": {
                "ClusterId": "location",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/location/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "location": {
                "ClusterId": "location",
                "Match": {
                    "Path": "/location/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/location/{**catch-all}"
                    }
                ]
            },
            "order-openapi-v1-public": {
                "ClusterId": "order",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/order/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "order": {
                "ClusterId": "order",
                "Match": {
                    "Path": "/order/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/order/{**catch-all}"
                    }
                ]
            },
            "product-openapi-v1-public": {
                "ClusterId": "product",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/product/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "product": {
                "ClusterId": "product",
                "Match": {
                    "Path": "/product/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/product/{**catch-all}"
                    }
                ]
            },
            "statistic": {
                "ClusterId": "statistic",
                "Match": {
                    "Path": "/statistic/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/statistic/{**catch-all}"
                    }
                ]
            },
            "imagegenerator": {
                "ClusterId": "imagegenerator",
                "Match": {
                    "Path": "/image-generator/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/image-generator/{**catch-all}"
                    }
                ]
            },
            "billing-openapi-v1-public": {
                "ClusterId": "billing",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/billing/openapi/v1-public/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/v1-public/openapi.json"
                    }
                ]
            },
            "billing": {
                "ClusterId": "billing",
                "Match": {
                    "Path": "/billing/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/billing/{**catch-all}"
                    }
                ]
            }
        },
        "Clusters": {
            "catalog": {
                "Destinations": {
                    "Default": {
                        "Address": "http://catalog-api",
                        "AccessTokenClientName": "teck-catalog",
                        "Swaggers": [
                            {
                                "PrefixPath": "/catalog",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json",
                                    "/openapi/v3-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "customer": {
                "Destinations": {
                    "Default": {
                        "Address": "http://customer-api",
                        "AccessTokenClientName": "teck-customer",
                        "Swaggers": [
                            {
                                "PrefixPath": "/customer",
                                "Paths": [
                                    "/openapi/v1-public/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "basket": {
                "Destinations": {
                    "Default": {
                        "Address": "http://basket-api",
                        "AccessTokenClientName": "teck-basket",
                        "Swaggers": [
