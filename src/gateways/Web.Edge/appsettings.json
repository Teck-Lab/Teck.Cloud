{
    "AppOptions": {
        "Name": "Gateway"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "SerilogOptions": {
        "WriteToFile": false,
        "StructuredConsoleLogging": false,
        "EnableEnrichers": true
    },
    "HealthOptions": {
        "Postgres": false,
        "Redis": false,
        "RabbitMq": false,
        "OpenIdConnectServer": true,
        "ApplicationStatus": true
    },
    "SwaggerOptions": {
        "Title": "Gateway Service",
        "Description": "Open API Documentation of Gateway Service"
    },
    "MultiTenancy": {
        "TenantIdHeaderName": "X-TenantId",
        "OrganizationClaimName": "organization",
        "TenantIdClaimName": "tenant_id"
    },
    "EdgeRouteSecurity": {
        "Enabled": true,
        "AdminPathSegment": "admin",
        "EmployeeRole": "platform-admin"
    },
    "Services": {
        "CatalogApi": {
            "Url": "http://catalog-api"
        },
        "CustomerApi": {
            "Url": "http://customer-api"
        },
        "AggregateGateway": {
            "Url": "http://web-aggregate-gateway"
        }
    },
    "ReverseProxy": {
        "Routes": {
            "aggregate-gateway-openapi": {
                "ClusterId": "aggregate-gateway",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/aggregate/openapi/{documentName}/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/{documentName}/openapi.json"
                    }
                ]
            },
            "catalog-openapi": {
                "ClusterId": "catalog",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/catalog/openapi/{documentName}/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/{documentName}/openapi.json"
                    }
                ]
            },
            "customer-openapi": {
                "ClusterId": "customer",
                "Order": -100,
                "AuthorizationPolicy": "anonymous",
                "Match": {
                    "Path": "/customer/openapi/{documentName}/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/{documentName}/openapi.json"
                    }
                ]
            },
            "customer-admin-create-tenant": {
                "ClusterId": "customer",
                "Order": -10,
                "Match": {
                    "Methods": [
                        "POST"
                    ],
                    "Path": "/customer/v1/Tenants"
                },
                "Metadata": {
                    "EdgeAccessPolicy": "EmployeeOnly",
                    "EdgeTenantPolicy": "None"
                },
                "Transforms": [
                    {
                        "PathPattern": "/customer/v1/Tenants"
                    }
                ]
            },
            "customer-admin-get-tenant": {
                "ClusterId": "customer",
                "Order": -10,
                "Match": {
                    "Methods": [
                        "GET"
                    ],
                    "Path": "/customer/v1/Tenants/{id}"
                },
                "Metadata": {
                    "EdgeAccessPolicy": "EmployeeOnly",
                    "EdgeTenantPolicy": "None"
                },
                "Transforms": [
                    {
                        "PathPattern": "/customer/v1/Tenants/{id}"
                    }
                ]
            },
            "aggregate": {
                "ClusterId": "aggregate-gateway",
                "Match": {
                    "Path": "/aggregate/{**catch-all}"
                },
                "Metadata": {
                    "EdgeTenantPolicy": "None"
                },
                "Transforms": [
                    {
                        "PathPattern": "/aggregate/{**catch-all}"
                    }
                ]
            },
            "catalog": {
                "ClusterId": "catalog",
                "Match": {
                    "Path": "/catalog/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/catalog/{**catch-all}"
                    }
                ]
            },
            "customer": {
                "ClusterId": "customer",
                "Match": {
                    "Path": "/customer/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/customer/{**catch-all}"
                    }
                ]
            }
        },
        "Clusters": {
            "aggregate-gateway": {
                "Destinations": {
                    "Default": {
                        "Address": "http://web-aggregate-gateway",
                        "AccessTokenClientName": "aggregate-gateway",
                        "Swaggers": [
                            {
                                "PrefixPath": "/aggregate",
                                "Paths": [
                                    "/openapi/v1/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "catalog": {
                "Destinations": {
                    "Default": {
                        "Address": "http://catalog-api",
                        "AccessTokenClientName": "teck-catalog",
                        "Swaggers": [
                            {
                                "PrefixPath": "/catalog",
                                "Paths": [
                                    "/openapi/v1/openapi.json",
                                    "/openapi/v3/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "customer": {
                "Destinations": {
                    "Default": {
                        "Address": "http://customer-api",
                        "AccessTokenClientName": "teck-customer",
                        "Swaggers": [
                            {
                                "PrefixPath": "/customer",
                                "Paths": [
                                    "/openapi/v1/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            }
        }
    },
    "AllowedHosts": "*"
}
