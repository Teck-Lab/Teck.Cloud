{
    "AppOptions": {
        "Name": "Admin Gateway"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "SerilogOptions": {
        "WriteToFile": false,
        "StructuredConsoleLogging": false,
        "EnableEnrichers": true
    },
    "HealthOptions": {
        "Postgres": false,
        "Redis": false,
        "RabbitMq": false,
        "OpenIdConnectServer": true,
        "ApplicationStatus": true
    },
    "AdminGateway": {
        "PlatformAdminRole": "platform-admin"
    },
    "Keycloak": {
        "verify-token-audience": true
    },
    "Services": {
        "CatalogApi": {
            "Url": "http://catalog-api"
        },
        "CustomerApi": {
            "Url": "http://customer-api"
        }
    },
    "ReverseProxy": {
        "Routes": {
            "catalog-openapi": {
                "ClusterId": "catalog",
                "Order": -100,
                "AuthorizationPolicy": "PlatformAdmin",
                "Match": {
                    "Path": "/catalog/openapi/{documentName}/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/{documentName}/openapi.json"
                    }
                ]
            },
            "customer-openapi": {
                "ClusterId": "customer",
                "Order": -100,
                "AuthorizationPolicy": "PlatformAdmin",
                "Match": {
                    "Path": "/customer/openapi/{documentName}/openapi.json"
                },
                "Transforms": [
                    {
                        "PathPattern": "/openapi/{documentName}/openapi.json"
                    }
                ]
            },
            "catalog-admin": {
                "ClusterId": "catalog",
                "AuthorizationPolicy": "PlatformAdmin",
                "Match": {
                    "Path": "/catalog/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/catalog/{**catch-all}"
                    }
                ]
            },
            "customer-admin": {
                "ClusterId": "customer",
                "AuthorizationPolicy": "PlatformAdmin",
                "Match": {
                    "Path": "/customer/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/customer/{**catch-all}"
                    }
                ]
            }
        },
        "Clusters": {
            "catalog": {
                "Destinations": {
                    "Default": {
                        "Address": "http://catalog-api",
                        "Swaggers": [
                            {
                                "PrefixPath": "/catalog",
                                "Paths": [
                                    "/openapi/v1/openapi.json",
                                    "/openapi/v3/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            },
            "customer": {
                "Destinations": {
                    "Default": {
                        "Address": "http://customer-api",
                        "Swaggers": [
                            {
                                "PrefixPath": "/customer",
                                "Paths": [
                                    "/openapi/v1/openapi.json"
                                ]
                            }
                        ]
                    }
                }
            }
        }
    },
    "AllowedHosts": "*"
}
