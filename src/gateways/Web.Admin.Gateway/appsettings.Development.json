{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Keycloak": {
    "realm": "teck-cloud-development",
    "auth-server-url": "https://auth.tecklab.dk/",
    "ssl-required": "none",
    "resource": "teck-admin-gateway",
    "verify-token-audience": true,
    "credentials": {
      "secret": ""
    },
    "use-resource-role-mappings": true,
    "confidential-port": 0
  },
  "Services": {
    "CatalogApi": {
      "Url": "https://localhost:7001"
    },
    "CustomerApi": {
      "Url": "https://localhost:7002"
    }
  }
}
