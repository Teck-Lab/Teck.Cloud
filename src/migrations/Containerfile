# syntax=docker/dockerfile:1.7
#
# Multi-stage Dockerfile for Teck.Cloud.Migrations
# Optimized for multi-platform, Docker cache, and best practices
#

# Build arguments for .NET image version support
ARG DOTNET_SDK_VERSION=10.0.300
ARG DOTNET_RUNTIME_VERSION=10.0.3
ARG DOTNET_ALPINE_VERSION=3.23
ARG ICU_LIBS_VERSION=76.1-r1

# This stage is used when running from VS in fast mode (Default for Debug configuration)
FROM mcr.microsoft.com/dotnet/sdk:${DOTNET_SDK_VERSION}-alpine${DOTNET_ALPINE_VERSION} AS build
ARG BUILD_CONFIGURATION=Release
ARG VERSION=1.0.0
WORKDIR /src

# Copy only project files and props for restore layer (maximizes cache)
COPY ["global.json", "."]
COPY ["nuget.config", "."]
COPY ["Directory.Packages.props", "."]
COPY ["Directory.Build.props", "."]
COPY ["src/Directory.Build.props", "src/"]
COPY ["src/migrations/Directory.Build.props", "src/migrations/"]
COPY ["src/buildingblocks/Directory.Build.props", "src/buildingblocks/"]
COPY ["src/migrations/Teck.Cloud.Migrations/Teck.Cloud.Migrations.csproj", "src/migrations/Teck.Cloud.Migrations/"]
COPY ["src/migrations/Teck.Cloud.Migrations.MySql/Teck.Cloud.Migrations.MySql.csproj", "src/migrations/Teck.Cloud.Migrations.MySql/"]
COPY ["src/migrations/Teck.Cloud.Migrations.PostgreSQL/Teck.Cloud.Migrations.PostgreSQL.csproj", "src/migrations/Teck.Cloud.Migrations.PostgreSQL/"]
COPY ["src/migrations/Teck.Cloud.Migrations.SqlServer/Teck.Cloud.Migrations.SqlServer.csproj", "src/migrations/Teck.Cloud.Migrations.SqlServer/"]
COPY ["src/aspire/Teck.Cloud.ServiceDefaults/Teck.Cloud.ServiceDefaults.csproj", "src/aspire/Teck.Cloud.ServiceDefaults/"]
COPY ["src/buildingblocks/SharedKernel.Core/SharedKernel.Core.csproj", "src/buildingblocks/SharedKernel.Core/"]
COPY ["src/buildingblocks/SharedKernel.Infrastructure/SharedKernel.Infrastructure.csproj", "src/buildingblocks/SharedKernel.Infrastructure/"]
COPY ["src/buildingblocks/SharedKernel.Persistence/SharedKernel.Persistence.csproj", "src/buildingblocks/SharedKernel.Persistence/"]

# Use Docker Buildx and TARGETPLATFORM to select the correct RID for multi-platform builds
ARG TARGETPLATFORM
# Default to x64 if not set
ARG RUNTIME_IDENTIFIER=linux-musl-x64

# Map TARGETPLATFORM to .NET RID
RUN --mount=type=cache,target=/root/.nuget/packages \
    --mount=type=cache,target=/root/.local/share/NuGet/v3-cache \
    if [ "$TARGETPLATFORM" = "linux/arm64" ]; then export RID=linux-musl-arm64; else export RID=linux-musl-x64; fi && \
    dotnet restore "src/migrations/Teck.Cloud.Migrations/Teck.Cloud.Migrations.csproj" -r $RID

# Copy everything else and build
COPY . .
WORKDIR "/src/src/migrations/Teck.Cloud.Migrations"

RUN --mount=type=cache,target=/root/.nuget/packages \
    --mount=type=cache,target=/root/.local/share/NuGet/v3-cache \
    if [ "$TARGETPLATFORM" = "linux/arm64" ]; then export RID=linux-musl-arm64; else export RID=linux-musl-x64; fi && \
    dotnet build "Teck.Cloud.Migrations.csproj" -c $BUILD_CONFIGURATION -r $RID \
        /p:Version=$VERSION \
        /p:TreatWarningsAsErrors=false \
        /p:RunAnalyzersDuringBuild=false \
        /p:EnforceCodeStyleInBuild=false

# This stage is used to publish the service project to be copied to the final stage
FROM build AS publish
ARG BUILD_CONFIGURATION=Release
ARG VERSION=1.0.0
ARG TARGETPLATFORM
ARG RUNTIME_IDENTIFIER=linux-musl-x64
RUN --mount=type=cache,target=/root/.nuget/packages \
    --mount=type=cache,target=/root/.local/share/NuGet/v3-cache \
    if [ "$TARGETPLATFORM" = "linux/arm64" ]; then export RID=linux-musl-arm64; else export RID=linux-musl-x64; fi && \
    dotnet publish "Teck.Cloud.Migrations.csproj" -c $BUILD_CONFIGURATION -o /app/publish -r $RID \
        /p:Version=$VERSION \
        /p:TreatWarningsAsErrors=false \
        /p:RunAnalyzersDuringBuild=false \
        /p:EnforceCodeStyleInBuild=false

# This stage is used in production or when running from VS in regular mode (Default when not using the Debug configuration)
FROM dhi.io/dotnet:10-alpine3.23 AS final
ARG DOTNET_SDK_VERSION
ARG DOTNET_RUNTIME_VERSION
ARG DOTNET_ALPINE_VERSION
ARG ICU_LIBS_VERSION

# Build arguments for metadata
ARG VERSION=1.0.0

# OCI Image Format Specification labels
# https://github.com/opencontainers/image-spec/blob/main/annotations.md
LABEL org.opencontainers.image.title="Teck Cloud Migrations" \
      org.opencontainers.image.description="Database migration runner for Teck platform" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.authors="Teck Team" \
      org.opencontainers.image.vendor="Teck" \
      org.opencontainers.image.base.name="dhi.io/dotnet:10-alpine3.23"

LABEL com.teck.service.name="migrations" \
      com.teck.service.type="job" \
      com.teck.service.tier="data"

ENV APP_UID=1000 \
    DOTNET_RUNNING_IN_CONTAINER=true \
    DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false \
    DOTNET_GCServer=1 \
    DOTNET_GCHeapHardLimitPercent=65 \
    DOTNET_GCConserveMemory=9 \
    DOTNET_GCLatencyLevel=Batch \
    DOTNET_EnableDiagnostics=0 \
    DOTNET_TieredPGO=1 \
    DOTNET_TC_QuickJitForLoops=1

WORKDIR /app
COPY --from=build /app/publish .
# DHI images are non-root by default (UID 65532) - using that user
USER 65532
ENTRYPOINT ["dotnet", "Teck.Cloud.Migrations.dll"]
