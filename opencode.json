{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": [
    "@ekroon/opencode-copilot-instructions",
    "oh-my-openagent@latest",
    "opencode-snip@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-agent-tmux@latest",
    "cc-safety-net@latest",
    "opencode-smart-title@latest",
    "opencode-mem@latest"
  ],
  "provider": {
    "qwen3-27b": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen3.5-27B (llama.cpp)",
      "options": {
        "baseURL": "http://localhost:8001/v1"
      },
      "models": {
        "qwen3.5-27b": {
          "name": "qwen3.5-27b"
        }
      }
    },
    "nemotron-nano": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Nemotron-3-Nano-Omni (llama.cpp)",
      "options": {
        "baseURL": "http://localhost:8002/v1"
      },
      "models": {
        "nemotron-nano": {
          "name": "nemotron-nano"
        }
      }
    }
  }
}
