<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.TestPlatform" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="ErrorOr" />
    <PackageReference Include="Bogus" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="TngTech.ArchUnitNET" />
    <PackageReference Include="TngTech.ArchUnitNET.xUnitV3" />
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\buildingblocks\SharedKernel.Core\SharedKernel.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\statistic\Statistic.Api\Statistic.Api.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\statistic\Statistic.Application\Statistic.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\statistic\Statistic.Domain\Statistic.Domain.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\statistic\Statistic.Infrastructure\Statistic.Infrastructure.csproj" />
    <ProjectReference Include="..\..\shared\Teck.Cloud.Arch.Tests\Teck.Cloud.Arch.Tests.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <ExcludeByFile>**/_/src/*;**/Migrations/*;**/obj/*;**/bin/*</ExcludeByFile>
  </PropertyGroup>

</Project>
