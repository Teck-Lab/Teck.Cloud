<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.TestPlatform" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="ErrorOr" />
    <PackageReference Include="Bogus" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="TngTech.ArchUnitNET" />
    <PackageReference Include="TngTech.ArchUnitNET.xUnitV3" />
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\services\basket\Basket.Api\Basket.Api.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\basket\Basket.Application\Basket.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\catalog\Catalog.Api\Catalog.Api.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\catalog\Catalog.Application\Catalog.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\customer\Customer.Api\Customer.Api.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\customer\Customer.Application\Customer.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\order\Order.Api\Order.Api.csproj" />
    <ProjectReference Include="..\..\..\..\src\services\order\Order.Application\Order.Application.csproj" />
    <ProjectReference Include="..\..\..\..\src\buildingblocks\SharedKernel.Core\SharedKernel.Core.csproj" />
    <ProjectReference Include="..\..\..\..\src\buildingblocks\SharedKernel.Persistence\SharedKernel.Persistence.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <ExcludeByFile>**/_/src/*;**/Migrations/*;**/obj/*;**/bin/*</ExcludeByFile>
    <!-- Ensures coverage tools exclude _/src and other non-solution files -->
  </PropertyGroup>
</Project>
