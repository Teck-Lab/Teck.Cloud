<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[*]SharedKernel.*,[*]Teck.Cloud.ServiceDefaults*</Exclude>
          <Include>[Catalog]*,[Catalog.Application]*,[Catalog.Domain]*,[Catalog.Infrastructure]*,[Catalog.Api]*</Include>
          <ExcludeByFile>**/obj/**,**/*.g.cs,**/PromotionAggregate/Promotion.cs</ExcludeByFile>
          <ExcludeByAttribute>ExcludeFromCodeCoverage,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>